# Production Environment Variables for Railway
# Copy these into Railway dashboard for each service

# ============================================
# API Service (api.phoenix.ai)
# ============================================
DATABASE_URL=
REDIS_URL=
LUCIA_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
ADMIN_SECRET_KEY=
OLLAMA_HOST=http://localhost:11434
NODE_ENV=production
APP_URL=https://phoenix.ai
API_URL=https://api.phoenix.ai

# ============================================
# Website Service (phoenix.ai)
# ============================================
NEXT_PUBLIC_API_URL=https://api.phoenix.ai
NEXT_PUBLIC_APP_URL=https://phoenix.ai
NEXT_PUBLIC_ADMIN_KEY=

# ============================================
# Admin Service (admin.phoenix.ai)
# ============================================
NEXT_PUBLIC_ADMIN_KEY=

# ============================================
# WebSocket Service (ws.phoenix.ai)
# ============================================
APP_URL=https://phoenix.ai
API_URL=https://api.phoenix.ai
REDIS_URL=
PORT=3003

# ============================================
# Workers Service
# ============================================
REDIS_URL=
OLLAMA_HOST=http://localhost:11434

